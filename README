# Launching the infrastructure
docker compose up -d

# Checking running containers
dokcer ps

# Launching the Kafka preview
docker exec -it kafka /opt/kafka/bin/kafka-console-consumer.sh --bootstrap-server localhost:9092 --topic crypto-topic --from-beginning

# Releasing a data stream (Ingestion)
source venv/bin/activated
python3 scripts/fetch_prices.py

# Starting spark processor
docker exec -it spark-master /opt/spark/bin/spark-submit \
  --packages org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1,org.postgresql:postgresql:42.6.0 \
  /opt/spark/spark_processor.py

# Database preview
docker exec -it postgres psql -U admin -d crypto_db -c "SELECT * FROM crypto_prices ORDER BY timestamp DESC LIMIT 10;"

What if something doesn't work? (Your checklist)
If you see errors, follow this list:
1. docker logs kafka – is Kafka Server started at the end?
2. netstat -tuln | grep 9092 – is the port open?
3. pip list | grep confluent – ​​are you in venv and do you have the library installed?
